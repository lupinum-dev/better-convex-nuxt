# File name should be .env.local

# Convex deployment URL (from `pnpm exec better-convex-nuxt-convex dev`)
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:giant-penguin-200 

# Optional: Convex HTTP site URL (auto-derived if not set)
# Only set this if your Convex HTTP endpoint differs from the standard pattern
# CONVEX_SITE_URL=https://your-deployment.convex.site

# Site URL for Better Auth callbacks (your app's public URL)
# Note: This is NOT the same as convex.siteUrl in nuxt.config!
SITE_URL=http://localhost:3000

# Required outside exact loopback development. Use only a header overwritten
# by your ingress with exactly one client IP.
BCN_AUTH_TRUSTED_CLIENT_IP_HEADER=

# Private HMAC key shared with the selected Convex deployment. Generate at
# least 32 bytes; never commit a real value or expose it through public config.
BCN_AUTH_PROXY_IP_SECRET=

# Set BETTER_AUTH_SECRETS only in the Convex deployment or its secret manager.
# Never copy that secret into Nuxt's .env.local.

# GitHub OAuth credentials
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
