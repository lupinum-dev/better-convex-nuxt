# File name should be .env.local

# ---------------------------------------------------------------------------
# Nuxt app / module env
# ---------------------------------------------------------------------------

# Primary module input
CONVEX_URL=https://your-deployment.convex.cloud

# Written by the Convex CLI, but not read by better-convex-nuxt itself
CONVEX_DEPLOYMENT=dev:giant-penguin-200

# Optional override when Convex HTTP actions do not match the normal derived host
# CONVEX_SITE_URL=https://your-deployment.convex.site

# ---------------------------------------------------------------------------
# Convex / Better Auth env
# ---------------------------------------------------------------------------

# Your public app URL. This is used by Better Auth inside convex/auth.ts.
# Do not confuse this with CONVEX_SITE_URL / convex.siteUrl.
SITE_URL=http://localhost:3000

# Must be set in Convex Dashboard for deployed auth flows.
BETTER_AUTH_SECRET=your_random_secret_at_least_32_chars

# GitHub OAuth credentials (only if GitHub auth is enabled)
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
