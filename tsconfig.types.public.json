{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@lupinum/trellis": ["./src/module.ts"],
      "@lupinum/trellis/auth": ["./src/runtime/auth/index.ts"],
      "@lupinum/trellis/args": ["./src/runtime/args/index.ts"],
      "@lupinum/trellis/composables": ["./src/runtime/composables/index.ts"],
      "@lupinum/trellis/functions": ["./src/runtime/functions/index.ts"],
      "@lupinum/trellis/feature": ["./src/runtime/feature/index.ts"],
      "@lupinum/trellis/mcp": ["./src/runtime/mcp/index.ts"],
      "@lupinum/trellis/type-primitives": ["./src/runtime/type-primitives/index.ts"],
      "@lupinum/trellis/server": ["./src/runtime/server/index.ts"],
      "@lupinum/trellis/testing": ["./src/runtime/testing/index.ts"],
      "@lupinum/trellis/trusted-forwarding": ["./src/runtime/trusted-forwarding/index.ts"],
      "@lupinum/trellis/visibility": ["./src/runtime/visibility/index.ts"]
    }
  },
  "include": ["tests/dts/**/*.ts"],
  "exclude": ["dist", "node_modules", "apps/harness", "tests/fixtures", "examples"]
}
