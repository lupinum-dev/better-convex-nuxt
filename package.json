{
  "name": "better-convex-nuxt",
  "version": "0.8.0-beta.0",
  "description": "Full-featured Convex integration for Nuxt with SSR, real-time subscriptions, and authentication",
  "keywords": [
    "authentication",
    "backend",
    "better-auth",
    "convex",
    "nuxt",
    "nuxt-module",
    "real-time",
    "ssr",
    "vue",
    "vue3",
    "websocket"
  ],
  "homepage": "https://better-convex-nuxt.vercel.app",
  "bugs": {
    "url": "https://github.com/lupinum-dev/better-convex-nuxt/issues"
  },
  "license": "MIT",
  "author": "Matthias Amon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lupinum-dev/better-convex-nuxt.git"
  },
  "bin": {
    "better-convex-nuxt-auth-schema": "./dist/runtime/cli/auth-schema.js",
    "better-convex-nuxt-convex": "./dist/runtime/cli/convex.js"
  },
  "files": [
    "dist",
    "LICENSES",
    "THIRD_PARTY_NOTICES.md",
    "security/upstream-convex-better-auth.json"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "auth-client": [
        "./dist/runtime/auth-client/index.d.ts"
      ],
      "convex-auth": [
        "./dist/runtime/convex-auth/index.d.ts"
      ],
      "convex-auth/convex.config": [
        "./dist/runtime/convex-auth/component/convex.config.d.ts"
      ],
      "convex-auth/_generated/component.js": [
        "./dist/runtime/convex-auth/component/_generated/component.d.ts"
      ],
      "convex-auth/test": [
        "./dist/runtime/convex-auth/test.d.ts"
      ],
      "errors": [
        "./dist/runtime/errors/index.d.ts"
      ],
      "server": [
        "./dist/runtime/server/index.d.ts"
      ],
      "server/createUserSyncTriggers": [
        "./dist/runtime/server/createUserSyncTriggers.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./auth-client": {
      "types": "./dist/runtime/auth-client/index.d.ts",
      "import": "./dist/runtime/auth-client/index.js"
    },
    "./convex-auth": {
      "types": "./dist/runtime/convex-auth/index.d.ts",
      "import": "./dist/runtime/convex-auth/index.js"
    },
    "./convex-auth/convex.config": {
      "types": "./dist/runtime/convex-auth/component/convex.config.d.ts",
      "import": "./dist/runtime/convex-auth/component/convex.config.js"
    },
    "./convex-auth/_generated/component.js": {
      "types": "./dist/runtime/convex-auth/component/_generated/component.d.ts"
    },
    "./convex-auth/test": {
      "types": "./dist/runtime/convex-auth/test.d.ts",
      "import": "./dist/runtime/convex-auth/test.js"
    },
    "./errors": {
      "types": "./dist/runtime/errors/index.d.ts",
      "import": "./dist/runtime/errors/index.js"
    },
    "./server": {
      "types": "./dist/runtime/server/index.d.ts",
      "import": "./dist/runtime/server/index.js"
    },
    "./server/createUserSyncTriggers": {
      "types": "./dist/runtime/server/createUserSyncTriggers.d.ts",
      "import": "./dist/runtime/server/createUserSyncTriggers.js"
    }
  },
  "scripts": {
    "build:devtools": "nuxi build src/runtime/devtools/ui --preset static && node scripts/normalize-devtools-build.mjs",
    "build:package": "nuxt-module-build prepare && pnpm run build:devtools && nuxt-module-build build",
    "prepack": "pnpm run build:package && pnpm run check:package-exports:dist --dist-only",
    "dev": "pnpm run dev:prepare && nuxi dev --cwd playground --dotenv .env.local --port 4578",
    "dev:build": "nuxi build --cwd playground --dotenv .env.local",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare --cwd playground --dotenv .env.local",
    "docs:api-surface": "node scripts/generate-api-surface.mjs",
    "docs:asvs": "node scripts/generate-asvs-evidence.mjs",
    "release:artifact": "node scripts/release.mjs artifact",
    "release:prepare": "node scripts/release.mjs prepare",
    "verify": "pnpm check && pnpm check:asvs && pnpm check:sbom && pnpm check:contracts",
    "verify:auth": "pnpm check:auth-backend && pnpm check:no-old-auth-runtime && pnpm check:auth-logical-ids && pnpm check:auth-provenance --source-only && pnpm check:auth-upstream && pnpm check:auth-schema && pnpm test:auth-adapter && pnpm test:oauth && pnpm test:auth-fuzz && pnpm test:auth-sentinels && pnpm test:auth-mutations && pnpm test:auth-concurrency && pnpm test:auth-export-sentinels && pnpm test:auth-mfa && pnpm test:mcp-auth && pnpm test:mcp-conformance",
    "release:verify": "node scripts/verify-release.mjs",
    "lint": "pnpm run check:no-starter-generated-artifacts && eslint .",
    "check:contracts": "pnpm run check:no-old-auth-runtime && pnpm run check:contract-fixtures && pnpm run check:package-exports",
    "check:contract-fixtures": "nuxt-module-build prepare && nuxt-module-build build && pnpm run check:contract-fixtures:dist",
    "check:contract-fixtures:dist": "pnpm run check:api-surface-docs && pnpm run check:workspace-deps && pnpm run check:consumer-smoke:dist && pnpm run check:missing-convex-api && pnpm run check:auth-disabled-build-graph && pnpm run check:better-auth-local-component && pnpm run check:better-auth-two-factor && pnpm run check:auth-security-plugins",
    "check:package-exports": "pnpm run build:package && pnpm run check:package-exports:dist",
    "check:package-exports:dist": "node scripts/check-package-exports.mjs --package nuxt",
    "check:auth-provenance": "node scripts/check-auth-provenance.mjs",
    "check:auth-schema": "node scripts/check-auth-schema.mjs",
    "check:auth-logical-ids": "node scripts/check-auth-logical-ids.mjs",
    "check:auth-advisories": "node scripts/check-auth-advisories.mjs",
    "check:auth-upstream": "node scripts/check-auth-upstream.mjs",
    "check:security-governance": "node scripts/check-security-governance.mjs",
    "check:auth-backend": "node scripts/check-auth-backend.mjs",
    "check:no-old-auth-runtime": "node scripts/check-no-old-auth-runtime.mjs",
    "check:api-surface-docs": "node scripts/generate-api-surface.mjs --check",
    "check:asvs": "node scripts/generate-asvs-evidence.mjs --check",
    "check:sbom": "node scripts/generate-sbom.mjs --package nuxt --check",
    "check:no-starter-generated-artifacts": "node scripts/check-no-starter-generated-artifacts.mjs",
    "check:workspace-deps": "node scripts/check-workspace-dependency-alignment.mjs",
    "check:candidate-apps": "node scripts/check-candidate-apps.mjs --package nuxt",
    "update:candidate-app-locks": "node scripts/update-candidate-app-locks.mjs",
    "check:consumer-smoke": "nuxt-module-build prepare && nuxt-module-build build && pnpm run check:consumer-smoke:dist",
    "check:consumer-smoke:dist": "nuxi prepare --cwd test/fixtures/consumer-smoke && nuxi typecheck --cwd test/fixtures/consumer-smoke",
    "check:missing-convex-api": "nuxi prepare --cwd test/fixtures/missing-convex-api && nuxi typecheck --cwd test/fixtures/missing-convex-api",
    "check:auth-disabled-build-graph": "node scripts/check-auth-disabled-build-graph.mjs",
    "check:better-auth-local-component": "tsc --noEmit -p test/fixtures/better-auth-local-component/tsconfig.json",
    "check:better-auth-two-factor": "tsc --noEmit -p test/fixtures/better-auth-two-factor/tsconfig.json",
    "check:auth-security-plugins": "tsc --noEmit -p test/fixtures/auth-security-plugins/tsconfig.json",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run check:boundaries && pnpm run test",
    "typecheck:module": "nuxt-module-build prepare && vue-tsc --noEmit",
    "typecheck:server": "nuxt-module-build prepare && tsc --noEmit -p src/runtime/server/tsconfig.json",
    "typecheck:fixtures": "pnpm run check:better-auth-local-component && pnpm run check:better-auth-two-factor && pnpm run check:auth-security-plugins",
    "typecheck": "pnpm run typecheck:module && pnpm run typecheck:server && pnpm run typecheck:fixtures",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "nuxt-module-build prepare && vitest run --project=unit --project=security --project=convex --project=nuxt --project=browser",
    "test:browser": "nuxt-module-build prepare && vitest run --project=browser",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:full": "node scripts/run-e2e.mjs --full",
    "test:auth-adapter": "nuxt-module-build prepare && vitest run --project=auth-adapter",
    "test:auth-cloud-staging": "node scripts/run-auth-cloud-staging.mjs",
    "test:auth-concurrency": "node scripts/run-auth-concurrency.mjs && node scripts/run-oauth-transport-quota.mjs && node scripts/run-oauth-code-concurrency.mjs",
    "test:auth-export-sentinels": "node scripts/run-auth-export-sentinels.mjs",
    "test:auth-fuzz": "nuxt-module-build prepare && vitest run --project=auth-fuzz",
    "test:auth-mfa": "node scripts/run-auth-mfa.mjs",
    "test:auth-mutations": "nuxt-module-build prepare && node scripts/run-auth-mutations.mjs",
    "test:auth-sentinels": "nuxt-module-build prepare && node scripts/run-auth-sentinels.mjs",
    "test:oauth": "nuxt-module-build prepare && vitest run --project=oauth",
    "test:mcp-auth": "node scripts/run-mcp-auth.mjs",
    "test:mcp-conformance": "node scripts/run-mcp-conformance.mjs",
    "test:dast:proxy": "nuxt-module-build prepare && nuxi prepare --cwd playground --dotenv .env.local && vitest run --project=e2e test/e2e/auth-proxy-plugin-routes.e2e.test.ts",
    "test:nuxt": "nuxt-module-build prepare && vitest run --project=nuxt",
    "test:watch": "nuxt-module-build prepare && vitest watch --project=unit --project=nuxt",
    "test:types": "pnpm run typecheck:module"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "1.7.0-rc.1",
    "@nuxt/kit": "^4.4.8",
    "convex-helpers": "0.1.114",
    "defu": "^6.1.5",
    "h3": "1.15.11",
    "jiti": "2.7.0",
    "ohash": "^2.0.11"
  },
  "devDependencies": {
    "@better-auth/api-key": "1.7.0-rc.1",
    "@better-auth/core": "1.7.0-rc.1",
    "@edge-runtime/vm": "^5.0.0",
    "@modelcontextprotocol/client": "2.0.0-beta.4",
    "@modelcontextprotocol/conformance": "0.1.16",
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/inspector": "0.22.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@modelcontextprotocol/server": "2.0.0-beta.4",
    "@nuxt/eslint-config": "^1.16.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "22.20.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/browser-playwright": "^4.1.8",
    "better-auth": "1.7.0-rc.1",
    "convex": "1.42.2",
    "convex-test": "^0.0.54",
    "eslint": "^10.7.0",
    "happy-dom": "^20.8.9",
    "kysely": "0.28.17",
    "mcp-remote": "0.1.38",
    "nuxt": "4.4.8",
    "oxfmt": "^0.59.0",
    "pkg-pr-new": "0.0.78",
    "playwright": "^1.61.1",
    "tar": "7.5.19",
    "typescript": "~5.9.3",
    "vite": "7.3.6",
    "vitest": "^4.1.8",
    "vitest-browser-vue": "^2.1.0",
    "vue-tsc": "^3.3.7"
  },
  "peerDependencies": {
    "better-auth": "1.7.0-rc.1",
    "convex": "1.42.2",
    "kysely": "0.28.17",
    "nuxt": "4.4.8"
  },
  "engines": {
    "node": "^22.12.0 || ^24.11.0 || >=26.0.0"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "pnpm": {
    "overrides": {
      "@babel/core@7.29.0": "7.29.6",
      "launch-editor@2.13.1": "2.14.1",
      "lodash@4.17.23": "4.18.0",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.5",
      "postcss@8.5.8": "8.5.10",
      "@hono/node-server@1.19.14": "2.0.11",
      "fast-uri@3.1.3": "3.1.4",
      "shell-quote@1.8.3": "1.9.0",
      "shell-quote@1.8.4": "1.9.0",
      "svgo@4.0.1": "4.0.2",
      "tar@7.5.10": "7.5.19",
      "tar@7.5.16": "7.5.19",
      "ws@8.18.0": "8.21.0",
      "ws@8.19.0": "8.21.0"
    }
  }
}
