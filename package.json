{
  "name": "@lupinum/trellis",
  "version": "0.3.4",
  "description": "Full-featured Convex integration for Nuxt with SSR, real-time subscriptions, authentication, and permissions",
  "keywords": [
    "authentication",
    "backend",
    "better-auth",
    "convex",
    "nuxt",
    "nuxt-module",
    "permissions",
    "real-time",
    "ssr",
    "vue",
    "vue3",
    "websocket"
  ],
  "homepage": "https://trellis.vercel.app",
  "bugs": {
    "url": "https://github.com/lupinum-dev/trellis/issues"
  },
  "license": "MIT",
  "author": "Matthias Amon <ma4m0>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lupinum-dev/trellis.git"
  },
  "bin": {
    "trellis": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "auth": [
        "./dist/runtime/auth/index.d.ts"
      ],
      "args": [
        "./dist/runtime/args/index.d.ts"
      ],
      "composables": [
        "./dist/runtime/composables/index.d.ts"
      ],
      "functions": [
        "./dist/runtime/functions/index.d.ts"
      ],
      "eslint": [
        "./dist/eslint/index.d.mts"
      ],
      "trusted-caller": [
        "./dist/runtime/trusted-caller/index.d.ts"
      ],
      "visibility": [
        "./dist/runtime/visibility/index.d.ts"
      ],
      "mcp": [
        "./dist/runtime/mcp/index.d.ts"
      ],
      "server": [
        "./dist/runtime/server/index.d.ts"
      ],
      "testing": [
        "./dist/runtime/testing/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./auth": {
      "types": "./dist/runtime/auth/index.d.ts",
      "import": "./dist/runtime/auth/index.js"
    },
    "./args": {
      "types": "./dist/runtime/args/index.d.ts",
      "import": "./dist/runtime/args/index.js"
    },
    "./composables": {
      "types": "./dist/runtime/composables/index.d.ts",
      "import": "./dist/runtime/composables/index.js"
    },
    "./functions": {
      "types": "./dist/runtime/functions/index.d.ts",
      "import": "./dist/runtime/functions/index.js"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.mts",
      "import": "./dist/eslint/index.mjs"
    },
    "./trusted-caller": {
      "types": "./dist/runtime/trusted-caller/index.d.ts",
      "import": "./dist/runtime/trusted-caller/index.js"
    },
    "./visibility": {
      "types": "./dist/runtime/visibility/index.d.ts",
      "import": "./dist/runtime/visibility/index.js"
    },
    "./mcp": {
      "types": "./dist/runtime/mcp/index.d.ts",
      "import": "./dist/runtime/mcp/index.js"
    },
    "./server": {
      "types": "./dist/runtime/server/index.d.ts",
      "import": "./dist/runtime/server/index.js"
    },
    "./testing": {
      "types": "./dist/runtime/testing/index.d.ts",
      "import": "./dist/runtime/testing/index.js"
    }
  },
  "scripts": {
    "build:cli": "tsc -p tsconfig.cli.json && node -e \"require('node:fs').chmodSync('dist/cli.mjs', 0o755)\"",
    "build:client": "nuxi generate client",
    "prepare:types": "nuxt-module-build prepare",
    "prepack": "nuxt-module-build build && pnpm run build:client && pnpm run build:cli",
    "dev": "pnpm run dev:prepare && nuxi dev --cwd test/internal-harness --dotenv .env.local",
    "dev:local": "INTERNAL_HARNESS_ENABLE_PRIVATE_BRIDGE_REFERENCE=true CONVEX_PRIVATE_BRIDGE_KEY=internal-harness-private-bridge-key-not-for-production USE_LOCAL_CONVEX=true pnpm run dev:prepare && INTERNAL_HARNESS_ENABLE_PRIVATE_BRIDGE_REFERENCE=true CONVEX_PRIVATE_BRIDGE_KEY=internal-harness-private-bridge-key-not-for-production USE_LOCAL_CONVEX=true nuxi dev --cwd test/internal-harness --dotenv .env.local",
    "dev:local:reset": "INTERNAL_HARNESS_ENABLE_PRIVATE_BRIDGE_REFERENCE=true CONVEX_PRIVATE_BRIDGE_KEY=internal-harness-private-bridge-key-not-for-production USE_LOCAL_CONVEX=true RESET_LOCAL_BACKEND=true pnpm run dev:prepare && INTERNAL_HARNESS_ENABLE_PRIVATE_BRIDGE_REFERENCE=true CONVEX_PRIVATE_BRIDGE_KEY=internal-harness-private-bridge-key-not-for-production USE_LOCAL_CONVEX=true RESET_LOCAL_BACKEND=true nuxi dev --cwd test/internal-harness --dotenv .env.local",
    "dev:build": "nuxi build --cwd test/internal-harness --dotenv .env.local",
    "dev:prepare": "pnpm run prepare:types && nuxt-module-build build --stub && pnpm run build:cli",
    "docs:api-surface": "node scripts/generate-api-surface.mjs",
    "check:docs:api-surface": "node scripts/generate-api-surface.mjs --check",
    "check:docs:links": "node scripts/check-doc-links.mjs",
    "harness:convex:codegen": "pnpm --dir test/internal-harness exec convex codegen",
    "harness:convex:dashboard": "docker run --rm -p 6791:6791 -e NEXT_PUBLIC_DEPLOYMENT_URL=http://127.0.0.1:3210 ghcr.io/get-convex/convex-dashboard:latest",
    "release:verify": "pnpm run lint && pnpm run test && pnpm run prepack && pnpm run test:types",
    "release": "pnpm run release:verify && changelogen --release && npm publish && git push --follow-tags",
    "lint": "pnpm run check:no-canonical-trusted-caller-wrappers && pnpm run check:no-query-composables-in-middleware && pnpm run check:no-use-route-in-middleware && pnpm run check:no-middleware-query-docs && pnpm run check:docs:api-surface && pnpm run check:docs:links && eslint .",
    "check:no-canonical-trusted-caller-wrappers": "sh -c '! rg -n \"withTrustedCallerHandler\\\\(\" README.md docs/content/docs/7.permissions docs/content/docs/13.mcp-tools examples test/internal-harness'",
    "check:no-query-composables-in-middleware": "sh -c '! rg -n \"useConvexQuery\\\\(|useConvexPaginatedQuery\\\\(\" test/internal-harness -g \"middleware/**\" -g \"plugins/**\"'",
    "check:no-use-route-in-middleware": "sh -c '! rg -n \"useRoute\\\\(\" test/internal-harness -g \"middleware/**\"'",
    "check:no-middleware-query-docs": "sh -c '! rg -n \"middleware[^\\n]{0,120}subscribe:\\s*false|subscribe:\\s*false[^\\n]{0,120}middleware\" docs/content/docs'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test:contracts": "vitest run --project=nuxt --project=server test/nuxt test/auth test/unit/cli-doctor.test.ts test/unit/module-auto-imports.test.ts test/unit/api-surface-doc.test.ts test/unit/runtime-facade-boundaries.test.ts",
    "test:internals": "vitest run --project=unit test/unit/auth-engine-state.test.ts test/unit/module-setup.test.ts test/unit/query-state.test.ts test/unit/pagination-state.test.ts test/unit/pagination-page-state.test.ts test/unit/pagination-runtime-state.test.ts test/unit/upload-queue-state.test.ts test/unit/shared-query-subscription.test.ts test/unit/upload-queue-runtime.test.ts test/unit/global-hooks.test.ts",
    "test": "vitest run --project=unit --project=convex --project=nuxt --project=server --project=browser",
    "test:auth": "vitest run --project=unit --project=nuxt --project=server test/auth",
    "test:browser": "vitest run --project=browser",
    "test:e2e": "pnpm run dev:prepare && vitest run --project=e2e",
    "test:e2e:full": "pnpm run dev:prepare && vitest run --project=e2e",
    "test:inventory": "rg --files test -g '!test/fixtures/**/node_modules/**' -g '!test/internal-harness/node_modules/**'",
    "test:list": "rg --files test -g '**/*.test.ts' -g '!test/fixtures/**' -g '!test/support/**' -g '!test/internal-harness/.nuxt/**' -g '!test/internal-harness/node_modules/**' | sort",
    "test:nuxt": "vitest run --project=nuxt",
    "test:server": "vitest run --project=server",
    "test:full": "vitest run --project=unit --project=convex --project=nuxt --project=server --project=browser --project=e2e",
    "test:watch": "vitest watch --project=unit --project=nuxt --project=server",
    "test:types": "vue-tsc -p tsconfig.nuxt.json --noEmit",
    "postinstall": "pnpm run prepare:types",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@convex-dev/better-auth": "^0.11.4",
    "@nuxt/devtools-kit": "^3.2.2",
    "@nuxt/kit": "^4.4.2",
    "better-auth": ">=1.5.0 <1.6.0",
    "citty": "^0.2.2",
    "consola": "^3.4.0",
    "defu": "^6.1.6",
    "h3": "1.15.11",
    "ohash": "^2.0.11",
    "sirv": "^3.0.1",
    "ufo": "^1.5.4"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/devtools-ui-kit": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/mcp-toolkit": "^0.13.3",
    "@nuxtjs/robots": "6.0.6",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.2",
    "ai": "^6.0.143",
    "changelogen": "^0.6.2",
    "convex": "^1.34.1",
    "convex-helpers": "^0.1.114",
    "convex-test": "^0.0.46",
    "convex-vite-plugin": "^0.4.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.4",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.2",
    "oxfmt": "^0.43.0",
    "playwright-core": "^1.59.1",
    "secure-exec": "^0.2.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2",
    "vitest-browser-vue": "^2.1.0",
    "vue-tsc": "^3.2.6",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nuxtjs/mcp-toolkit": "^0.13.3",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.114",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "@nuxtjs/mcp-toolkit": {
      "optional": true
    },
    "convex-helpers": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "lint-staged": {
    "!(**/_generated/**/*)": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "pnpm": {
    "overrides": {
      "h3": "1.15.11"
    }
  }
}
