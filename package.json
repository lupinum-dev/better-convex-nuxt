{
  "name": "better-convex-nuxt",
  "version": "0.3.0",
  "description": "Full-featured Convex integration for Nuxt with SSR, real-time subscriptions, authentication, and permissions",
  "keywords": [
    "authentication",
    "backend",
    "better-auth",
    "convex",
    "nuxt",
    "nuxt-module",
    "permissions",
    "real-time",
    "ssr",
    "vue",
    "vue3",
    "websocket"
  ],
  "homepage": "https://better-convex-nuxt.vercel.app",
  "bugs": {
    "url": "https://github.com/lupinum-dev/better-convex-nuxt/issues"
  },
  "license": "MIT",
  "author": "Matthias Amon <ma4m0>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lupinum-dev/better-convex-nuxt.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "composables": [
        "./dist/runtime/composables/index.d.ts"
      ],
      "server": [
        "./dist/runtime/server/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./composables": {
      "types": "./dist/runtime/composables/index.d.ts",
      "import": "./dist/runtime/composables/index.js"
    },
    "./server": {
      "types": "./dist/runtime/server/index.d.ts",
      "import": "./dist/runtime/server/index.js"
    }
  },
  "scripts": {
    "build:devtools": "nuxi build src/runtime/devtools/ui --preset static",
    "prepack": "npm run build:devtools && nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxi dev --cwd playground --dotenv .env.local",
    "dev:build": "nuxi build --cwd playground --dotenv .env.local",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare --cwd playground --dotenv .env.local",
    "docs:api-surface": "node scripts/generate-api-surface.mjs",
    "release": "npm run lint && npm run test && npm run prepack && git tag -l | xargs git tag -d && git fetch --tags origin && changelogen --release && npm publish && git push --follow-tags",
    "lint": "npm run check:no-legacy-query-api && npm run check:no-query-composables-in-middleware && npm run check:no-use-route-in-middleware && npm run check:no-middleware-query-docs && eslint .",
    "check:no-legacy-query-api": "sh -c '! rg -n \"useConvexQueryLazy|useConvexPaginatedQueryLazy\" src playground docs test'",
    "check:no-query-composables-in-middleware": "sh -c '! rg -n \"useConvexQuery\\\\(|useConvexPaginatedQuery\\\\(\" playground/middleware playground/plugins'",
    "check:no-use-route-in-middleware": "sh -c '! rg -n \"useRoute\\\\(\" playground/middleware'",
    "check:no-middleware-query-docs": "sh -c '! rg -n \"middleware[^\\n]{0,120}subscribe:\\s*false|subscribe:\\s*false[^\\n]{0,120}middleware\" docs/content/docs'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run --project=unit --project=convex --project=nuxt --project=browser",
    "test:browser": "vitest run --project=browser",
    "test:e2e": "vitest run --project=e2e",
    "test:e2e:full": "vitest run --project=e2e",
    "test:nuxt": "vitest run --project=nuxt",
    "test:full": "vitest run --project=unit --project=convex --project=nuxt --project=browser",
    "test:watch": "vitest watch --project=unit --project=nuxt",
    "test:types": "vue-tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.10.11",
    "@nuxt/devtools-kit": "^3.2.2",
    "@nuxt/kit": "^4.3.1",
    "better-auth": "^1.4.19",
    "convex": "^1.32.0",
    "defu": "^6.1.4",
    "h3": "1.15.5",
    "ohash": "^2.0.11"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@nuxt/devtools": "^3.2.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/robots": "5.7.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "latest",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/browser-playwright": "^4.0.18",
    "changelogen": "^0.6.2",
    "convex-test": "^0.0.41",
    "eslint": "^10.0.2",
    "happy-dom": "^20.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nuxt": "^4.3.1",
    "oxfmt": "^0.35.0",
    "playwright-core": "^1.58.2",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18",
    "vitest-browser-vue": "^2.0.2",
    "vue-tsc": "^3.2.5"
  },
  "lint-staged": {
    "!(**/_generated/**/*)": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}
