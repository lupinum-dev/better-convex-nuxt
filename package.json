{
  "name": "better-convex-nuxt",
  "version": "0.3.4",
  "description": "Full-featured Convex integration for Nuxt with SSR, real-time subscriptions, authentication, and permissions",
  "keywords": [
    "authentication",
    "backend",
    "better-auth",
    "convex",
    "nuxt",
    "nuxt-module",
    "permissions",
    "real-time",
    "ssr",
    "vue",
    "vue3",
    "websocket"
  ],
  "homepage": "https://better-convex-nuxt.vercel.app",
  "bugs": {
    "url": "https://github.com/lupinum-dev/better-convex-nuxt/issues"
  },
  "license": "MIT",
  "author": "Matthias Amon <ma4m0>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lupinum-dev/better-convex-nuxt.git"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "better-convex-nuxt": "./dist/cli.mjs"
  },
  "type": "module",
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "composables": [
        "./dist/runtime/composables/index.d.ts"
      ],
      "schema": [
        "./dist/runtime/schema/index.d.ts"
      ],
      "mcp": [
        "./dist/runtime/mcp/index.d.ts"
      ],
      "server": [
        "./dist/runtime/server/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./composables": {
      "types": "./dist/runtime/composables/index.d.ts",
      "import": "./dist/runtime/composables/index.js"
    },
    "./schema": {
      "types": "./dist/runtime/schema/index.d.ts",
      "import": "./dist/runtime/schema/index.js"
    },
    "./mcp": {
      "types": "./dist/runtime/mcp/index.d.ts",
      "import": "./dist/runtime/mcp/index.js"
    },
    "./server": {
      "types": "./dist/runtime/server/index.d.ts",
      "import": "./dist/runtime/server/index.js"
    }
  },
  "scripts": {
    "build:cli": "tsc -p tsconfig.cli.json && node -e \"require('node:fs').chmodSync('dist/cli.mjs', 0o755)\"",
    "build:devtools": "nuxi build src/runtime/devtools/ui --preset static",
    "prepack": "npm run build:devtools && nuxt-module-build build && npm run build:cli",
    "dev": "npm run dev:prepare && nuxi dev --cwd playground --dotenv .env.local",
    "dev:local": "PLAYGROUND_ENABLE_PRIVATE_BRIDGE_REFERENCE=true CONVEX_PRIVATE_BRIDGE_KEY=playground-private-bridge-key-not-for-production USE_LOCAL_CONVEX=true npm run dev:prepare && PLAYGROUND_ENABLE_PRIVATE_BRIDGE_REFERENCE=true CONVEX_PRIVATE_BRIDGE_KEY=playground-private-bridge-key-not-for-production USE_LOCAL_CONVEX=true nuxi dev --cwd playground --dotenv .env.local",
    "dev:local:reset": "PLAYGROUND_ENABLE_PRIVATE_BRIDGE_REFERENCE=true CONVEX_PRIVATE_BRIDGE_KEY=playground-private-bridge-key-not-for-production USE_LOCAL_CONVEX=true RESET_LOCAL_BACKEND=true npm run dev:prepare && PLAYGROUND_ENABLE_PRIVATE_BRIDGE_REFERENCE=true CONVEX_PRIVATE_BRIDGE_KEY=playground-private-bridge-key-not-for-production USE_LOCAL_CONVEX=true RESET_LOCAL_BACKEND=true nuxi dev --cwd playground --dotenv .env.local",
    "dev:build": "nuxi build --cwd playground --dotenv .env.local",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare --cwd playground --dotenv .env.local",
    "docs:api-surface": "node scripts/generate-api-surface.mjs",
    "playground:convex:codegen": "pnpm --dir playground exec convex codegen",
    "playground:convex:dashboard": "docker run --rm -p 6791:6791 -e NEXT_PUBLIC_DEPLOYMENT_URL=http://127.0.0.1:3210 ghcr.io/get-convex/convex-dashboard:latest",
    "release": "npm run lint && npm run test && npm run prepack && git tag -l | xargs git tag -d && git fetch --tags origin && changelogen --release && npm publish && git push --follow-tags",
    "lint": "npm run check:no-legacy-query-api && npm run check:no-query-composables-in-middleware && npm run check:no-use-route-in-middleware && npm run check:no-middleware-query-docs && eslint .",
    "check:no-legacy-query-api": "echo 'No legacy query API names to check'",
    "check:no-query-composables-in-middleware": "sh -c '! rg -n \"useConvexQuery\\\\(|useConvexPaginatedQuery\\\\(\" playground/middleware playground/plugins'",
    "check:no-use-route-in-middleware": "sh -c '! rg -n \"useRoute\\\\(\" playground/middleware'",
    "check:no-middleware-query-docs": "sh -c '! rg -n \"middleware[^\\n]{0,120}subscribe:\\s*false|subscribe:\\s*false[^\\n]{0,120}middleware\" docs/content/docs'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run --project=unit --project=convex --project=nuxt --project=browser",
    "test:browser": "vitest run --project=browser",
    "test:e2e": "vitest run --project=e2e",
    "test:e2e:full": "vitest run --project=e2e",
    "test:nuxt": "vitest run --project=nuxt",
    "test:full": "vitest run --project=unit --project=convex --project=nuxt --project=browser",
    "test:watch": "vitest watch --project=unit --project=nuxt",
    "test:types": "vue-tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@convex-dev/better-auth": "^0.11.3",
    "@nuxt/devtools-kit": "^3.2.2",
    "@nuxt/kit": "^4.3.1",
    "better-auth": ">=1.5.0 <1.6.0",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "convex": "^1.34.0",
    "defu": "^6.1.4",
    "h3": "1.15.10",
    "ohash": "^2.0.11"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@nuxt/devtools": "^3.2.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/mcp-toolkit": "^0.12.0",
    "@nuxtjs/robots": "5.7.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "latest",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/browser-playwright": "^4.0.18",
    "changelogen": "^0.6.2",
    "convex-helpers": "^0.1.114",
    "convex-test": "^0.0.41",
    "convex-vite-plugin": "^0.4.0",
    "eslint": "^9.39.3",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "nuxt": "^4.3.1",
    "oxfmt": "^0.36.0",
    "playwright-core": "^1.58.2",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18",
    "vitest-browser-vue": "^2.0.2",
    "vue-tsc": "^3.2.5",
    "zod": "^4.3.0"
  },
  "peerDependencies": {
    "@nuxtjs/mcp-toolkit": "^0.12.0",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.114",
    "zod": "^4.3.0"
  },
  "peerDependenciesMeta": {
    "@nuxtjs/mcp-toolkit": {
      "optional": true
    },
    "convex": {
      "optional": true
    },
    "convex-helpers": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "lint-staged": {
    "!(**/_generated/**/*)": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "pnpm": {
    "overrides": {
      "h3": "1.15.10"
    }
  }
}
