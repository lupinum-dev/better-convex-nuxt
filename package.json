{
  "name": "better-convex-nuxt",
  "version": "0.6.0",
  "description": "Full-featured Convex integration for Nuxt with SSR, real-time subscriptions, and authentication",
  "keywords": [
    "authentication",
    "backend",
    "better-auth",
    "convex",
    "nuxt",
    "nuxt-module",
    "real-time",
    "ssr",
    "vue",
    "vue3",
    "websocket"
  ],
  "homepage": "https://better-convex-nuxt.vercel.app",
  "bugs": {
    "url": "https://github.com/lupinum-dev/better-convex-nuxt/issues"
  },
  "license": "MIT",
  "author": "Matthias Amon <ma4m0>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lupinum-dev/better-convex-nuxt.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "auth-client": [
        "./dist/runtime/auth-client/index.d.ts"
      ],
      "errors": [
        "./dist/runtime/errors/index.d.ts"
      ],
      "server": [
        "./dist/runtime/server/index.d.ts"
      ],
      "server/createUserSyncTriggers": [
        "./dist/runtime/server/createUserSyncTriggers.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./auth-client": {
      "types": "./dist/runtime/auth-client/index.d.ts",
      "import": "./dist/runtime/auth-client/index.js"
    },
    "./errors": {
      "types": "./dist/runtime/errors/index.d.ts",
      "import": "./dist/runtime/errors/index.js"
    },
    "./server": {
      "types": "./dist/runtime/server/index.d.ts",
      "import": "./dist/runtime/server/index.js"
    },
    "./server/createUserSyncTriggers": {
      "types": "./dist/runtime/server/createUserSyncTriggers.d.ts",
      "import": "./dist/runtime/server/createUserSyncTriggers.js"
    }
  },
  "scripts": {
    "build:devtools": "nuxi build src/runtime/devtools/ui --preset static",
    "prepack": "nuxt-module-build prepare && npm run build:devtools && nuxt-module-build build && npm run check:package-exports",
    "dev": "npm run dev:prepare && nuxi dev --cwd playground --dotenv .env.local --port 4578",
    "dev:build": "nuxi build --cwd playground --dotenv .env.local",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare --cwd playground --dotenv .env.local",
    "docs:api-surface": "node scripts/generate-api-surface.mjs",
    "release": "node scripts/release.mjs",
    "lint": "npm run check:vocabulary && npm run check:no-starter-generated-artifacts && eslint .",
    "check:contracts": "npm run check:api-surface-docs && npm run check:package-exports && npm run check:workspace-deps && npm run check:consumer-smoke && npm run check:missing-convex-api && npm run check:better-auth-local-component && npm run check:platform-auth-oauth-proof",
    "check:package-exports": "node scripts/check-package-exports.mjs",
    "check:api-surface-docs": "node scripts/generate-api-surface.mjs --check",
    "check:vocabulary": "node scripts/check-vocabulary.mjs",
    "check:no-starter-generated-artifacts": "node scripts/check-no-starter-generated-artifacts.mjs",
    "check:workspace-deps": "node scripts/check-workspace-dependency-alignment.mjs",
    "check:consumer-smoke": "nuxt-module-build build && nuxi prepare --cwd test/fixtures/consumer-smoke && nuxi typecheck --cwd test/fixtures/consumer-smoke",
    "check:missing-convex-api": "nuxi prepare --cwd test/fixtures/missing-convex-api && nuxi typecheck --cwd test/fixtures/missing-convex-api",
    "check:auth-disabled-build-graph": "node scripts/check-auth-disabled-build-graph.mjs",
    "check:better-auth-local-component": "tsc --noEmit -p test/fixtures/better-auth-local-component/tsconfig.json",
    "check:platform-auth-oauth-proof": "tsc --noEmit -p test/fixtures/platform-auth-oauth-proof/tsconfig.json",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "benchmark:server-auth-cache": "node scripts/benchmark-server-auth-cache.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck:module && npm run typecheck:server && npm run check:boundaries && npm run test",
    "typecheck:module": "nuxt-module-build prepare && vue-tsc --noEmit",
    "typecheck:server": "tsc --noEmit -p src/runtime/server/tsconfig.json",
    "typecheck:fixtures": "npm run check:better-auth-local-component && npm run check:platform-auth-oauth-proof",
    "typecheck": "npm run typecheck:module && npm run typecheck:server && npm run typecheck:fixtures",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run --project=unit --project=convex --project=nuxt --project=browser",
    "test:browser": "vitest run --project=browser",
    "test:e2e": "nuxi prepare --cwd playground --dotenv .env.local && vitest run --project=e2e",
    "test:e2e:full": "nuxi prepare --cwd playground --dotenv .env.local && vitest run --project=e2e",
    "test:nuxt": "vitest run --project=nuxt",
    "test:full": "vitest run --project=unit --project=convex --project=nuxt --project=browser",
    "test:watch": "vitest watch --project=unit --project=nuxt",
    "test:types": "npm run typecheck:module",
    "prepare": "husky"
  },
  "dependencies": {
    "@convex-dev/better-auth": "0.12.5",
    "@nuxt/devtools-kit": "^3.2.2",
    "@nuxt/kit": "^4.4.7",
    "better-auth": "1.6.23",
    "convex": "1.38.0",
    "defu": "^6.1.4",
    "h3": "1.15.5",
    "ohash": "^2.0.11"
  },
  "devDependencies": {
    "@better-auth/api-key": "1.6.23",
    "@edge-runtime/vm": "^5.0.0",
    "@nuxt/devtools": "^3.2.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.7",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/robots": "5.7.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "22.20.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/browser-playwright": "^4.0.18",
    "changelogen": "^0.6.2",
    "convex-test": "^0.0.41",
    "eslint": "^9.39.4",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "nuxt": "4.4.7",
    "oxfmt": "^0.36.0",
    "playwright-core": "^1.58.2",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18",
    "vitest-browser-vue": "^2.0.2",
    "vue-tsc": "^3.2.5"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0"
  },
  "lint-staged": {
    "!(**/_generated/**/*)": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": "^22.12.0 || ^24.11.0 || >=26.0.0"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
