{
  "extends": "../tsconfig.nuxt.json",
  "include": [
    "../.nuxt/**/*.d.ts",
    "../.nuxt/**/*.ts",
    "./**/*.ts",
    "./**/*.mts",
    "./**/*.d.ts",
    "./**/*.vue"
  ],
  "exclude": [
    "../dist",
    "../node_modules",
    "../test/internal-harness",
    "../test/fixtures",
    "../docs",
    "../examples",
    "./runtime/server"
  ]
}
