{
  "name": "@lupinum/trellis-bridge",
  "version": "0.0.0",
  "description": "Bridge package boundary for Trellis-aware Convex component integrations",
  "type": "module",
  "private": true,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./component": {
      "types": "./dist/component.d.ts",
      "import": "./dist/component.js",
      "default": "./dist/component.js"
    }
  },
  "peerDependencies": {
    "@lupinum/trellis": "workspace:*",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.114"
  },
  "dependencies": {
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@lupinum/trellis": "workspace:*"
  }
}
