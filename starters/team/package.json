{
  "name": "better-convex-nuxt-starter-team",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --dotenv .env.local",
    "build": "nuxt build --dotenv .env.local",
    "preview": "nuxt preview --dotenv .env.local",
    "convex:configure": "better-convex-nuxt-convex configure",
    "convex:dev": "better-convex-nuxt-convex dev",
    "convex:codegen": "better-convex-nuxt-convex codegen",
    "convex:local:once": "better-convex-nuxt-convex dev --anonymous --once --typecheck try --typecheck-components",
    "lint": "../../node_modules/.bin/oxfmt --check app server convex/*.ts convex/lib/*.ts convex/betterAuth/*.ts scripts test package.json README.md",
    "test": "nuxi prepare --dotenv .env.local && vitest run",
    "typecheck": "nuxt typecheck --dotenv .env.local",
    "verify": "pnpm lint && pnpm test && pnpm convex:codegen && pnpm typecheck && pnpm build",
    "verify:release": "pnpm verify && pnpm convex:local:once",
    "verify:browser": "node scripts/verify-browser-happy-path.mjs",
    "verify:browser:mobile": "node scripts/verify-browser-happy-path.mjs --mobile",
    "verify:full": "pnpm verify:release && pnpm verify:browser"
  },
  "dependencies": {
    "@convex-dev/rate-limiter": "^0.3.2",
    "better-auth": "1.7.0-rc.1",
    "better-convex-nuxt": "0.8.0-beta.9",
    "convex": "1.42.2",
    "kysely": "0.28.17",
    "nuxt": "4.4.8",
    "vue": "3.5.39",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@nuxt/schema": "4.4.8",
    "@types/node": "^25.0.0",
    "convex-test": "^0.0.41",
    "playwright": "^1.61.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.18",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.7"
  },
  "packageManager": "pnpm@10.30.3"
}
