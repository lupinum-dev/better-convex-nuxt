{
  "name": "better-convex-nuxt-starter-mcp-agent",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "convex:dev": "nuxi prepare && convex dev",
    "convex:codegen": "nuxi prepare && convex codegen",
    "lint": "../../node_modules/.bin/oxfmt --check app server convex/*.ts scripts shared package.json README.md",
    "test": "nuxi prepare && vitest run",
    "typecheck": "nuxt typecheck",
    "verify": "pnpm lint && pnpm test && pnpm convex:codegen && pnpm typecheck && pnpm build",
    "verify:browser": "node scripts/verify-browser-happy-path.mjs",
    "verify:browser:mobile": "node scripts/verify-browser-happy-path.mjs --mobile",
    "verify:full": "pnpm verify && pnpm verify:browser && pnpm verify:browser:mobile"
  },
  "dependencies": {
    "@convex-dev/better-auth": "0.12.5",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@nuxtjs/mcp-toolkit": "^0.17.2",
    "better-auth": "1.6.23",
    "better-convex-nuxt": "^0.4.0",
    "convex": "1.38.0",
    "h3": "^1.15.5",
    "nuxt": "4.4.8",
    "vue": "^3.5.25",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^25.0.0",
    "convex-test": "^0.0.41",
    "typescript": "~5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "pnpm@10.30.3"
}
