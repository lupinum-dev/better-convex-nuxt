{
  "name": "better-convex-nuxt-starter-mcp-oauth-agent",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --dotenv .env.local",
    "build": "nuxt build --dotenv .env.local",
    "convex:configure": "nuxi prepare --dotenv .env.local && better-convex-nuxt-convex configure",
    "convex:codegen": "nuxi prepare --dotenv .env.local && better-convex-nuxt-convex codegen",
    "convex:dev": "nuxi prepare --dotenv .env.local && better-convex-nuxt-convex dev",
    "typecheck": "nuxt typecheck --dotenv .env.local",
    "verify": "pnpm convex:codegen && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "1.7.0-rc.1",
    "@better-convex/mcp": "0.1.0-beta.1",
    "@modelcontextprotocol/server": "2.0.0-beta.5",
    "better-auth": "1.7.0-rc.1",
    "better-convex-nuxt": "0.8.0-beta.10",
    "convex": "1.42.2",
    "kysely": "0.28.17",
    "nuxt": "4.4.8",
    "vue": "3.5.39",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "typescript": "~5.9.3",
    "vue-tsc": "^3.3.7"
  },
  "packageManager": "pnpm@10.30.3"
}
